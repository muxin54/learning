# ============================================
# .env.example —— 环境变量模板
# 复制此文件为 .env 并填入你的真实配置
# .env 不会被提交到 git（已在 .gitignore 中）
# ============================================

# 数据库连接
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5433/fastapi_learning

# JWT 配置（请改成随机字符串！）
SECRET_KEY=change-me-to-a-random-string
ALGORITHM=HS256
EXPIRE_MINUTES=60

# 应用
APP_NAME=FastAPI Demo
DEBUG=true
